---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<aside class="mdx-example" aria-label="MDX Component example">
  <p>{label}</p>
</aside>

<style>
  .mdx-example {
    border: 1px solid var(--color-border);
    border-left: 0.25rem solid var(--color-prose-accent);
    border-radius: var(--radius-md);
    padding: 1rem;
    background: var(--color-prose-accent-soft);
  }

  .mdx-example p {
    margin: 0;
  }
</style>
