---
import {
  getSiteMenuItemInitialExpanded,
  getSiteMenuItemState,
  type SiteMenuItem,
} from "../../lib/site/menu";
import { withBase } from "../../lib/utils/paths";

type Props = {
  item: SiteMenuItem;
  indexPath: string;
  level: number;
  idPrefix: string;
  currentPath: string;
  basePath: string;
};

const { item, indexPath, level, idPrefix, currentPath, basePath } = Astro.props;
const hasChildren = Boolean(item.children?.length);
const state = getSiteMenuItemState(item, currentPath, basePath);
const isCurrent = state === "current";
const isAncestor = state === "ancestor";
const isExpanded = getSiteMenuItemInitialExpanded(item, currentPath, basePath);
const itemClasses = [
  "site-menu-item",
  `level-${level}`,
  hasChildren ? "has-children" : null,
  isCurrent ? "is-current" : null,
  isAncestor ? "is-ancestor" : null,
]
  .filter(Boolean)
  .join(" ");

function menuGroupId(idPrefix: string, indexPath: string): string {
  return `${idPrefix}-group-${indexPath.replaceAll(".", "-")}`;
}
---

<li class={itemClasses}>
  <div class="site-menu-row">
    <a
      class="site-menu-link"
      href={withBase(item.href)}
      aria-current={isCurrent ? "page" : undefined}
    >
      {item.label}
    </a>
    {
      hasChildren ? (
        <button
          class="site-menu-toggle"
          type="button"
          data-disclosure-toggle
          aria-label={`${item.label} の子項目を開閉する`}
          aria-expanded={isExpanded ? "true" : "false"}
          aria-controls={menuGroupId(idPrefix, indexPath)}
        >
          <span class="site-menu-caret" aria-hidden="true" />
        </button>
      ) : null
    }
  </div>

  {
    hasChildren ? (
      <ul
        id={menuGroupId(idPrefix, indexPath)}
        class="site-menu-list"
        hidden={!isExpanded}
      >
        {item.children?.map((child, childIndex) => (
          <Astro.self
            item={child}
            indexPath={`${indexPath}.${childIndex + 1}`}
            level={level + 1}
            idPrefix={idPrefix}
            currentPath={currentPath}
            basePath={basePath}
          />
        ))}
      </ul>
    ) : null
  }
</li>
