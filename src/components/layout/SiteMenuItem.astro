---
import type { SiteMenuItem } from "../../lib/site/menu";
import { withBase } from "../../lib/utils/paths";

type Props = {
  item: SiteMenuItem;
  indexPath: string;
  level: number;
  idPrefix: string;
};

const { item, indexPath, level, idPrefix } = Astro.props;
const hasChildren = Boolean(item.children?.length);

function menuGroupId(idPrefix: string, indexPath: string): string {
  return `${idPrefix}-group-${indexPath.replaceAll(".", "-")}`;
}
---

<li class={`site-menu-item level-${level}`}>
  <div class="site-menu-row">
    <a class="site-menu-link" href={withBase(item.href)}>
      {item.label}
    </a>
    {
      hasChildren ? (
        <button
          class="site-menu-toggle"
          type="button"
          data-disclosure-toggle
          aria-label={`${item.label} の子項目を開閉する`}
          aria-expanded={item.defaultExpanded ? "true" : "false"}
          aria-controls={menuGroupId(idPrefix, indexPath)}
        >
          <span class="site-menu-caret" aria-hidden="true" />
        </button>
      ) : null
    }
  </div>

  {
    hasChildren ? (
      <ul
        id={menuGroupId(idPrefix, indexPath)}
        class="site-menu-list"
        hidden={!item.defaultExpanded}
      >
        {item.children?.map((child, childIndex) => (
          <Astro.self
            item={child}
            indexPath={`${indexPath}.${childIndex + 1}`}
            level={level + 1}
            idPrefix={idPrefix}
          />
        ))}
      </ul>
    ) : null
  }
</li>
