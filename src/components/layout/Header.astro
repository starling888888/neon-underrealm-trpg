---
import { siteMeta } from "../../lib/site/siteMeta";
import { withBase } from "../../lib/utils/paths";
import SearchButton from "../search/SearchButton.astro";

export interface Props {
  showMobileSiteMenu?: boolean;
}

const { showMobileSiteMenu = true } = Astro.props;
const homePath = withBase("/");
const logoWebpPath = withBase(siteMeta.titleLogo.webp);
---

<header class="site-header" data-site-header>
  {
    showMobileSiteMenu ? (
      <div class="mobile-header-control">
        <button
          class="icon-button"
          type="button"
          data-mobile-menu-open
          aria-label="サイトメニューを開く"
          aria-expanded="false"
          aria-controls="mobile-site-menu-drawer"
        >
          <span class="menu-icon" aria-hidden="true"></span>
        </button>
      </div>
    ) : (
      <div class="mobile-header-control" aria-hidden="true"></div>
    )
  }

  <a class="site-logo-link" href={homePath} aria-label={`${siteMeta.title} トップページへ`}>
    <img
      class="site-logo"
      src={logoWebpPath}
      width={siteMeta.titleLogo.width}
      height={siteMeta.titleLogo.height}
      alt={siteMeta.title}
      decoding="async"
    />
  </a>

  <div class="header-actions">
    <SearchButton variant="desktop" />
  </div>

  <div class="mobile-header-control">
    <SearchButton variant="mobile" />
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    z-index: 5;
    inset-block-start: 0;
    inset-inline: 0;
    width: 100%;
    min-height: 5.5rem;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: var(--space-8);
    background: var(--color-surface-inverse);
    color: var(--color-text-inverse);
    padding-inline: var(--space-8);
    transition: transform 180ms ease;
  }

  .site-header.is-hidden {
    transform: translateY(-100%);
  }

  .site-logo-link {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    color: var(--color-text-inverse);
    text-decoration: none;
  }

  .site-logo-link:hover {
    color: var(--color-text-inverse);
  }

  .site-logo {
    width: auto;
    height: 3rem;
  }

  .header-actions {
    display: flex;
    justify-content: flex-end;
  }

  .mobile-header-control {
    display: none;
  }

  .icon-button {
    width: 2.5rem;
    height: 2.5rem;
    display: inline-grid;
    place-items: center;
    border: var(--border-width) solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    background: transparent;
    color: var(--color-text-inverse);
    opacity: 1;
  }

  .icon-button:disabled {
    cursor: default;
  }

  .icon-button:not(:disabled) {
    cursor: pointer;
  }

  .icon-button:not(:disabled):hover {
    background: rgb(248 250 249 / 0.1);
  }

  .menu-icon,
  .menu-icon::before,
  .menu-icon::after {
    width: 1.125rem;
    height: 0.125rem;
    display: block;
    border-radius: var(--radius-sm);
    background: var(--color-text-inverse);
  }

  .menu-icon {
    position: relative;
  }

  .menu-icon::before,
  .menu-icon::after {
    content: "";
    position: absolute;
    left: 0;
  }

  .menu-icon::before {
    top: -0.44rem;
  }

  .menu-icon::after {
    top: 0.44rem;
  }

  @media (width < 48rem) {
    .site-header {
      inline-size: 100vw;
      min-height: 4rem;
      grid-template-columns: 2.5rem minmax(0, 1fr) 2.5rem;
      gap: var(--space-3);
      padding-inline: var(--space-3);
    }

    .mobile-header-control {
      display: block;
    }

    .site-logo-link {
      justify-self: center;
    }

    .site-logo {
      height: 1.875rem;
    }

    .header-actions {
      display: none;
    }
  }

  @media (width >= 48rem) {
    .site-header.is-hidden {
      transform: none;
    }
  }
</style>
