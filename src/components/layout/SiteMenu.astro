---
import { siteMenuItems, type SiteMenuItem } from "../../lib/site/menu";
import { withBase } from "../../lib/utils/paths";

function menuGroupId(indexPath: string): string {
  return `site-menu-group-${indexPath.replaceAll(".", "-")}`;
}

type RenderItem = {
  item: SiteMenuItem;
  indexPath: string;
  level: number;
};

const renderItems: RenderItem[] = siteMenuItems.map((item, index) => ({
  item,
  indexPath: String(index + 1),
  level: 1,
}));
---

<nav class="site-menu" aria-label="サイトメニュー">
  <p class="site-menu-kicker">SITE MENU</p>
  <p class="site-menu-title">サイトメニュー</p>

  <ul class="site-menu-list site-menu-list-root">
    {
      renderItems.map(({ item, indexPath, level }) => (
        <li class={`site-menu-item level-${level}`}>
          <div class="site-menu-row">
            {item.children?.length ? (
              <button
                class="site-menu-toggle"
                type="button"
                aria-label={`${item.label} の子項目を開閉する`}
                aria-expanded={item.defaultExpanded ? "true" : "false"}
                aria-controls={menuGroupId(indexPath)}
              >
                <span class="site-menu-caret" aria-hidden="true" />
              </button>
            ) : (
              <span class="site-menu-spacer" aria-hidden="true" />
            )}
            <a class="site-menu-link" href={withBase(item.href)}>
              {item.label}
            </a>
          </div>

          {item.children?.length ? (
            <ul
              id={menuGroupId(indexPath)}
              class="site-menu-list"
              hidden={!item.defaultExpanded}
            >
              {item.children.map((child, childIndex) => (
                <li class={`site-menu-item level-${level + 1}`}>
                  <div class="site-menu-row">
                    {child.children?.length ? (
                      <button
                        class="site-menu-toggle"
                        type="button"
                        aria-label={`${child.label} の子項目を開閉する`}
                        aria-expanded={child.defaultExpanded ? "true" : "false"}
                        aria-controls={menuGroupId(`${indexPath}.${childIndex + 1}`)}
                      >
                        <span class="site-menu-caret" aria-hidden="true" />
                      </button>
                    ) : (
                      <span class="site-menu-spacer" aria-hidden="true" />
                    )}
                    <a class="site-menu-link" href={withBase(child.href)}>
                      {child.label}
                    </a>
                  </div>

                  {child.children?.length ? (
                    <ul
                      id={menuGroupId(`${indexPath}.${childIndex + 1}`)}
                      class="site-menu-list"
                      hidden={!child.defaultExpanded}
                    >
                      {child.children.map((grandchild) => (
                        <li class={`site-menu-item level-${level + 2}`}>
                          <div class="site-menu-row">
                            <span class="site-menu-spacer" aria-hidden="true" />
                            <a class="site-menu-link" href={withBase(grandchild.href)}>
                              {grandchild.label}
                            </a>
                          </div>
                        </li>
                      ))}
                    </ul>
                  ) : null}
                </li>
              ))}
            </ul>
          ) : null}
        </li>
      ))
    }
  </ul>
</nav>

<script>
  const toggleButtons = document.querySelectorAll<HTMLButtonElement>(".site-menu-toggle");

  toggleButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const controlledId = button.getAttribute("aria-controls");
      const controlledList = controlledId ? document.getElementById(controlledId) : null;

      if (!controlledList) {
        return;
      }

      const isExpanded = button.getAttribute("aria-expanded") === "true";

      button.setAttribute("aria-expanded", String(!isExpanded));
      controlledList.hidden = isExpanded;
    });
  });
</script>

<style>
  .site-menu {
    position: sticky;
    top: var(--space-6);
  }

  .site-menu-kicker,
  .site-menu-title {
    margin: 0;
  }

  .site-menu-kicker {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    font-weight: 700;
    line-height: var(--line-height-tight);
  }

  .site-menu-title {
    margin-block-start: var(--space-3);
    padding-block-end: var(--space-5);
    border-bottom: var(--border-width) solid var(--color-border);
    color: var(--color-text);
    font-size: var(--text-base);
    font-weight: 700;
    line-height: var(--line-height-tight);
  }

  .site-menu-list {
    display: grid;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-menu-list[hidden] {
    display: none;
  }

  .site-menu-list-root {
    margin-block-start: var(--space-5);
  }

  .site-menu-item {
    min-width: 0;
  }

  .site-menu-item .site-menu-list {
    margin-block: var(--space-1) var(--space-2);
  }

  .site-menu-row {
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    align-items: center;
    column-gap: var(--space-2);
    min-height: 2rem;
  }

  .level-2 {
    padding-inline-start: var(--space-4);
  }

  .level-3 {
    padding-inline-start: var(--space-8);
  }

  .site-menu-toggle,
  .site-menu-spacer {
    width: 1rem;
    height: 1rem;
  }

  .site-menu-toggle {
    display: inline-grid;
    place-items: center;
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0;
  }

  .site-menu-toggle:hover {
    background: color-mix(in srgb, var(--color-accent-soft) 68%, transparent);
    color: var(--color-link-hover);
  }

  .site-menu-toggle:focus-visible,
  .site-menu-link:focus-visible {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  .site-menu-caret {
    width: 0;
    height: 0;
    display: block;
    border-block: 0.28rem solid transparent;
    border-inline-start: 0.4rem solid currentColor;
    transform: rotate(90deg);
    transition: transform 120ms ease;
  }

  .site-menu-toggle[aria-expanded="false"] .site-menu-caret {
    transform: rotate(0deg);
  }

  .site-menu-link {
    min-width: 0;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: var(--line-height-tight);
    overflow-wrap: anywhere;
    padding: var(--space-1) var(--space-2);
    text-decoration: none;
    transition:
      background-color 120ms ease,
      color 120ms ease,
      box-shadow 120ms ease;
  }

  .level-1 > .site-menu-row .site-menu-link {
    font-weight: 700;
  }

  .level-2 > .site-menu-row .site-menu-link {
    font-weight: 600;
  }

  .level-3 > .site-menu-row .site-menu-link {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  .site-menu-link:hover {
    background: color-mix(in srgb, var(--color-accent-soft) 72%, transparent);
    color: var(--color-link-hover);
    box-shadow: inset 0.18rem 0 0 var(--color-link);
  }

  @media (max-width: 48rem) {
    .site-menu {
      display: none;
    }
  }
</style>
