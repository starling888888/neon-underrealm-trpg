---
import SiteMenuItem from "./SiteMenuItem.astro";
import { siteMenuItems } from "../../lib/site/menu";

type Props = {
  idPrefix?: string;
  variant?: "desktop" | "drawer";
};

const { idPrefix = "site-menu", variant = "desktop" } = Astro.props;
---

<nav class={`site-menu site-menu-${variant}`} aria-label="サイトメニュー">
  <p class="site-menu-kicker">SITE MENU</p>
  <p class="site-menu-title">サイトメニュー</p>
  <ul class="site-menu-list site-menu-list-root">
    {
      siteMenuItems.map((item, index) => (
        <SiteMenuItem
          item={item}
          indexPath={String(index + 1)}
          level={1}
          idPrefix={idPrefix}
        />
      ))
    }
  </ul>
</nav>

<script>
  import { setupDisclosure } from "../../scripts/disclosure";

  const siteMenus = document.querySelectorAll(".site-menu");

  siteMenus.forEach((siteMenu) => {
    setupDisclosure(siteMenu);
  });
</script>

<style>
  .site-menu {
    position: sticky;
    top: var(--space-6);
  }

  .site-menu-drawer {
    position: static;
  }

  .site-menu-kicker,
  .site-menu-title {
    margin: 0;
  }

  .site-menu-kicker {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    font-weight: 700;
    line-height: var(--line-height-tight);
  }

  .site-menu-title {
    margin-block-start: var(--space-3);
    padding-block-end: var(--space-5);
    border-bottom: var(--border-width) solid var(--color-border);
    color: var(--color-text);
    font-size: var(--text-base);
    font-weight: 700;
    line-height: var(--line-height-tight);
  }

  .site-menu :global(.site-menu-list) {
    display: grid;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-menu :global([hidden]) {
    display: none;
  }

  .site-menu :global(.site-menu-list-root) {
    margin-block-start: var(--space-5);
  }

  .site-menu :global(.site-menu-item) {
    min-width: 0;
  }

  .site-menu :global(.site-menu-item .site-menu-list) {
    margin-block: var(--space-1) var(--space-2);
  }

  .site-menu :global(.site-menu-row) {
    display: grid;
    grid-template-columns: 1rem minmax(0, 1fr);
    align-items: center;
    column-gap: var(--space-2);
    min-height: 2rem;
  }

  .site-menu :global(.level-2) {
    padding-inline-start: var(--space-4);
  }

  .site-menu :global(.level-3) {
    padding-inline-start: var(--space-8);
  }

  .site-menu :global(.site-menu-toggle),
  .site-menu :global(.site-menu-spacer) {
    width: 1rem;
    height: 1rem;
  }

  .site-menu :global(.site-menu-toggle) {
    display: inline-grid;
    place-items: center;
    border: 0;
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    padding: 0;
  }

  .site-menu :global(.site-menu-toggle:hover) {
    background: color-mix(in srgb, var(--color-accent-soft) 68%, transparent);
    color: var(--color-link-hover);
  }

  .site-menu :global(.site-menu-toggle:focus-visible),
  .site-menu :global(.site-menu-link:focus-visible) {
    outline: var(--focus-ring-width) solid var(--color-focus);
    outline-offset: var(--focus-ring-offset);
  }

  .site-menu :global(.site-menu-caret) {
    width: 0;
    height: 0;
    display: block;
    border-block: 0.28rem solid transparent;
    border-inline-start: 0.4rem solid currentColor;
    transform: rotate(90deg);
    transition: transform 120ms ease;
  }

  .site-menu :global(.site-menu-toggle[aria-expanded="false"] .site-menu-caret) {
    transform: rotate(0deg);
  }

  .site-menu :global(.site-menu-link) {
    min-width: 0;
    border-radius: var(--radius-sm);
    color: var(--color-text);
    font-size: var(--text-sm);
    line-height: var(--line-height-tight);
    overflow-wrap: anywhere;
    padding: var(--space-1) var(--space-2);
    text-decoration: none;
    transition:
      background-color 120ms ease,
      color 120ms ease,
      box-shadow 120ms ease;
  }

  .site-menu :global(.level-1 > .site-menu-row .site-menu-link) {
    font-weight: 700;
  }

  .site-menu :global(.level-2 > .site-menu-row .site-menu-link) {
    font-weight: 600;
  }

  .site-menu :global(.level-3 > .site-menu-row .site-menu-link) {
    color: var(--color-text-muted);
    font-size: var(--text-xs);
  }

  .site-menu :global(.site-menu-link:hover) {
    background: color-mix(in srgb, var(--color-accent-soft) 72%, transparent);
    color: var(--color-link-hover);
    box-shadow: inset 0.18rem 0 0 var(--color-link);
  }

  @media (max-width: 48rem) {
    .site-menu-desktop {
      display: none;
    }
  }
</style>
