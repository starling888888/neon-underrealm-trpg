---
interface Props {
  anchorId?: string;
  name: string;
  maxLevel: number;
  timing: string;
  cost?: string | null;
  proficiency: string;
  acquisitionRestriction?: string | null;
  usageRestriction?: string | null;
  target: string;
  range?: string | null;
  summary: string;
  effect: string;
  variant?: "default" | "legend";
}

const {
  anchorId,
  name,
  maxLevel,
  timing,
  cost,
  proficiency,
  acquisitionRestriction,
  usageRestriction,
  target,
  range,
  summary,
  effect,
  variant = "default",
} = Astro.props;

function displayValue(value: string | null | undefined): string {
  return value?.trim() || "-";
}
---

<article id={anchorId} class:list={["skill-card", `skill-card-${variant}`]} data-skill-card>
  <header class="skill-card-header">
    <h3 class="skill-card-name">{name}</h3>
    <span class="skill-card-max-level">最大LV: {maxLevel}</span>
  </header>

  <p class="skill-card-meta">
    <span>{timing}</span>
    <span>{displayValue(cost)}</span>
    <span>{proficiency}</span>
  </p>

  <dl class="skill-card-details">
    <div class="skill-card-detail skill-card-detail-acquisition">
      <dt>取得制限</dt>
      <dd>{displayValue(acquisitionRestriction)}</dd>
    </div>
    <div class="skill-card-detail">
      <dt>使用制限</dt>
      <dd>{displayValue(usageRestriction)}</dd>
    </div>
    <div class="skill-card-detail">
      <dt>対象</dt>
      <dd>{target}</dd>
    </div>
    <div class="skill-card-detail">
      <dt>射程</dt>
      <dd>{displayValue(range)}</dd>
    </div>
  </dl>

  <div class="skill-card-effect">
    <p class="skill-card-summary">{summary}</p>
    <p class="skill-card-rule">{effect}</p>
  </div>
</article>

<style>
  .skill-card {
    min-width: 0;
    min-height: 25.5rem;
    height: 100%;
    border: var(--border-width) solid var(--color-border);
    background: var(--color-surface);
    padding: var(--space-4);
  }

  .skill-card-header {
    display: flex;
    min-width: 0;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .skill-card-name {
    min-width: 0;
    margin: 0;
    border-left: 0;
    color: var(--color-text);
    font-size: var(--text-xl);
    line-height: var(--line-height-tight);
    padding: 0;
  }

  .skill-card-name::after {
    display: block;
    width: 2rem;
    height: 0.125rem;
    margin-top: var(--space-2);
    background: var(--color-link);
    content: "";
  }

  .skill-card-max-level {
    flex: 0 0 auto;
    color: var(--color-link);
    font-size: var(--text-xs);
    font-weight: 800;
    line-height: var(--line-height-tight);
    white-space: nowrap;
  }

  .skill-card-meta {
    display: flex;
    min-width: 0;
    flex-wrap: wrap;
    margin: var(--space-3) 0 0;
    color: var(--color-prose-accent);
    font-size: var(--text-sm);
    font-weight: 750;
    line-height: var(--line-height-tight);
  }

  .skill-card-meta span {
    padding-inline: var(--space-2);
    border-right: var(--border-width) solid var(--color-border);
  }

  .skill-card-meta span:first-child {
    padding-left: 0;
  }

  .skill-card-meta span:last-child {
    border-right: 0;
  }

  .skill-card-details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: var(--space-4) 0 0;
    border-top: var(--border-width) solid var(--color-border);
    border-left: var(--border-width) solid var(--color-border);
  }

  .skill-card-detail {
    min-width: 0;
    min-height: 3.1875rem;
    padding: var(--space-2);
    border-right: var(--border-width) solid var(--color-border);
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .skill-card-detail dt {
    color: var(--color-text-muted);
    font-size: 0.625rem;
    font-weight: 750;
    line-height: var(--line-height-tight);
  }

  .skill-card-detail dd {
    margin: var(--space-1) 0 0;
    color: var(--color-text);
    font-size: var(--text-xs);
    font-weight: 500;
    line-height: var(--line-height-tight);
    overflow-wrap: anywhere;
  }

  .skill-card-detail-acquisition dd {
    font-weight: 800;
  }

  .skill-card-effect {
    margin-top: var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-xs);
    line-height: 1.72;
  }

  .skill-card-effect p {
    margin: 0;
    white-space: pre-line;
  }

  .skill-card-rule {
    color: var(--color-text);
    font-weight: 750;
  }

  .skill-card-summary + .skill-card-rule {
    margin-top: var(--space-2);
  }

  @media (max-width: 48rem) {
    .skill-card {
      min-height: 23.5rem;
      padding: var(--space-3);
    }

    .skill-card-name {
      font-size: var(--text-base);
    }

    .skill-card-name::after {
      width: 1.5rem;
      margin-top: var(--space-2);
    }

    .skill-card-max-level {
      font-size: 0.625rem;
    }

    .skill-card-meta {
      margin-top: var(--space-2);
      font-size: 0.625rem;
    }

    .skill-card-meta span {
      padding-inline: var(--space-1);
    }

    .skill-card-details {
      margin-top: var(--space-3);
    }

    .skill-card-detail {
      min-height: 2.875rem;
      padding: 0.375rem;
    }

    .skill-card-detail dt {
      font-size: 0.5rem;
    }

    .skill-card-detail dd {
      font-size: 0.625rem;
    }

    .skill-card-effect {
      margin-top: var(--space-2);
      font-size: 0.625rem;
      line-height: 1.62;
    }
  }
</style>
