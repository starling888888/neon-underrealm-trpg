---
import {
  displayText,
  displayValue,
  type DisplayValue,
} from "./card-display";

interface Props {
  anchorId?: string;
  name: string;
  maxLevel: DisplayValue;
  timing: string;
  cost?: string | null;
  proficiency?: string | null;
  acquisitionRestriction?: string | null;
  usageRestriction?: string | null;
  target?: string | null;
  range?: string | null;
  summary?: string | null;
  effect?: string | null;
  variant?: "default" | "legend";
}

const {
  anchorId,
  name,
  maxLevel,
  timing,
  cost,
  proficiency,
  acquisitionRestriction,
  usageRestriction,
  target,
  range,
  effect,
  variant = "default",
} = Astro.props;

---

<article
  id={anchorId}
  class:list={["data-card", "skill-card", `skill-card-${variant}`]}
  data-skill-card
>
  <div class="data-card-content skill-card-content">
    <header class="data-card-header skill-card-header">
      <span class="data-card-name skill-card-name">{name}</span>
    </header>

    <p class="skill-card-max-level">最大LV: {maxLevel}</p>

    <p class="data-card-meta">
      <span>{timing}</span>
      <span>{displayValue(cost)}</span>
      <span>{displayValue(proficiency)}</span>
    </p>

    <dl class="data-card-details skill-card-details">
      <div class="data-card-detail skill-card-detail-acquisition">
        <dt>取得制限</dt>
        <dd>{displayValue(acquisitionRestriction)}</dd>
      </div>
      <div class="data-card-detail skill-card-detail">
        <dt>使用制限</dt>
        <dd>{displayValue(usageRestriction)}</dd>
      </div>
      <div class="data-card-detail skill-card-detail">
        <dt>対象</dt>
        <dd>{displayValue(target)}</dd>
      </div>
      <div class="data-card-detail skill-card-detail">
        <dt>射程</dt>
        <dd>{displayValue(range)}</dd>
      </div>
    </dl>

    <div class="data-card-effect skill-card-effect">
      <p class="data-card-rule skill-card-rule">{displayText(effect)}</p>
    </div>
  </div>
</article>

<style>
  .skill-card-max-level {
    margin: 0.75rem 0 0;
    color: var(--color-link);
    font-size: var(--text-sm);
    font-weight: 800;
    line-height: var(--line-height-tight);
    white-space: nowrap;
  }

</style>
