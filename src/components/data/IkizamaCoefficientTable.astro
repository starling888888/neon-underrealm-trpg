---
import type { Ikizama } from "../../lib/schemas/ikizama";

interface Props {
  ikizamaList: readonly Ikizama[];
}

const { ikizamaList } = Astro.props;
---

<table data-ikizama-coefficients>
  <thead>
    <tr>
      <th scope="col">生き様</th>
      <th scope="col">初期体力係数</th>
      <th scope="col">初期精神力係数</th>
      <th scope="col">4レベル体力係数</th>
      <th scope="col">4レベル精神力係数</th>
      <th scope="col">10レベル体力係数</th>
      <th scope="col">10レベル精神力係数</th>
    </tr>
  </thead>
  <tbody>
    {
      ikizamaList.map((ikizama) => {
        const coefficients = ikizama.secondaryAttributeCoefficients;

        return (
          <tr data-ikizama-id={ikizama.id}>
            <th scope="row">{ikizama.name}</th>
            <td>{coefficients.level1.health}</td>
            <td>{coefficients.level1.mind}</td>
            <td>{coefficients.level4.health}</td>
            <td>{coefficients.level4.mind}</td>
            <td>{coefficients.level10.health}</td>
            <td>{coefficients.level10.mind}</td>
          </tr>
        );
      })
    }
  </tbody>
</table>
