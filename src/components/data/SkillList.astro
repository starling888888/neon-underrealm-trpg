---
import type { Skill } from "../../lib/schemas/skill";
import SkillCard from "./SkillCard.astro";

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<div class="skill-list" data-skill-list>
  {skills.map((skill) => <SkillCard {...skill} anchorId={skill.id} />)}
</div>

<style>
  .skill-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  @media (max-width: 48rem) {
    .skill-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-3);
      margin-top: var(--space-4);
    }
  }
</style>
