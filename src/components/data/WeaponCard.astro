---
import {
  displayText,
  displayValue,
  type DisplayValue,
} from "./card-display";

interface Props {
  anchorId?: string;
  name: string;
  credit?: DisplayValue;
  kind?: DisplayValue;
  check?: DisplayValue;
  attack?: DisplayValue;
  guard?: DisplayValue;
  ammo?: DisplayValue;
  range?: DisplayValue;
  effect?: string | null;
}

const { anchorId, name, credit, kind, check, attack, guard, ammo, range, effect } =
  Astro.props;
---

<article id={anchorId} class="data-card weapon-card" data-weapon-card>
  <div class="data-card-content">
    <header class="data-card-header">
      <span class="data-card-name">{name}</span>
    </header>

    <p class="data-card-meta"><span class="data-card-credit">信用：{displayValue(credit)}</span></p>
    <p class="data-card-meta data-card-meta-secondary">
      <span>{displayValue(kind)}武器</span>
      <span>技能：{displayValue(check)}</span>
    </p>

    <dl class="data-card-details">
      <div class="data-card-detail">
        <dt>攻撃力</dt>
        <dd>{displayValue(attack)}</dd>
      </div>
      <div class="data-card-detail">
        <dt>ガード値</dt>
        <dd>{displayValue(guard)}</dd>
      </div>
      <div class="data-card-detail">
        <dt>射程</dt>
        <dd>{displayValue(range)}</dd>
      </div>
      <div class="data-card-detail">
        <dt>装弾数</dt>
        <dd>{displayValue(ammo)}</dd>
      </div>
    </dl>

    <div class="data-card-effect">
      <p class="data-card-rule">{displayText(effect)}</p>
    </div>
  </div>
</article>
