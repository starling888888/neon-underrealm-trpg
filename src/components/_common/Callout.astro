---
type CalloutType =
  | "note"
  | "tip"
  | "warning"
  | "danger"
  | "example"
  | "version";

interface Props {
  type: CalloutType;
  title?: string;
  titleAsHeading?: boolean;
}

const { type, title, titleAsHeading = false } = Astro.props;

const defaultTitles = {
  note: "補足",
  tip: "運用のコツ",
  warning: "注意",
  danger: "重要な注意",
  example: "例",
  version: "変更点",
} satisfies Record<CalloutType, string>;

const markers = {
  note: "i",
  tip: "?",
  warning: "!",
  danger: "!!",
  example: "#",
  version: "v",
} satisfies Record<CalloutType, string>;

const calloutTitle = title ?? defaultTitles[type];
const marker = markers[type];
const CalloutTitle = titleAsHeading ? "h2" : "span";
---

<aside class:list={["callout", `callout-${type}`]} data-callout-type={type}>
  <div class="callout-heading">
    <span class="callout-marker" aria-hidden="true">{marker}</span>
    <CalloutTitle class="callout-title">{calloutTitle}</CalloutTitle>
  </div>
  <div class="callout-body">
    <slot />
  </div>
</aside>

<style>
  .callout {
    --callout-accent: var(--color-prose-accent);
    --callout-border: color-mix(
      in srgb,
      var(--callout-accent) 30%,
      var(--color-border)
    );
    --callout-bg: var(--color-prose-accent-soft);
    --callout-muted: var(--color-text-muted);

    max-width: 100%;
    margin-block: var(--space-6);
    border: var(--border-width) solid var(--callout-border);
    border-left: 0.375rem solid var(--callout-accent);
    border-radius: var(--radius-md);
    background: var(--callout-bg);
    color: var(--color-text);
    padding: var(--space-5);
  }

  .callout-tip {
    --callout-accent: var(--color-link);
    --callout-border: color-mix(
      in srgb,
      var(--color-link) 28%,
      var(--color-border)
    );
    --callout-bg: var(--color-accent-soft);
    --callout-muted: var(--color-link-hover);
  }

  .callout-warning {
    --callout-accent: var(--color-warning);
    --callout-border: color-mix(
      in srgb,
      var(--color-warning) 45%,
      var(--color-border)
    );
    --callout-bg: var(--color-warning-soft);
    --callout-muted: #6b5b24;
  }

  .callout-danger {
    --callout-accent: var(--color-danger);
    --callout-border: color-mix(
      in srgb,
      var(--color-danger) 45%,
      var(--color-border)
    );
    --callout-bg: var(--color-danger-soft);
    --callout-muted: #8f3333;
  }

  .callout-example {
    --callout-accent: #5f7686;
    --callout-border: #94aeba;
    --callout-bg: #eef6f8;
    --callout-muted: #526775;
  }

  .callout-version {
    --callout-accent: var(--color-surface-inverse);
    --callout-border: var(--color-border-strong);
    --callout-bg: var(--color-surface-muted);
    --callout-muted: var(--color-text-muted);
  }

  .callout-heading {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    min-width: 0;
  }

  .callout-marker {
    display: inline-grid;
    flex: 0 0 auto;
    width: 2rem;
    height: 2rem;
    place-items: center;
    border: 0.125rem solid var(--callout-accent);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--callout-accent);
    font-size: var(--text-sm);
    font-weight: 800;
    line-height: 1;
  }

  .callout-title {
    margin: 0;
    border: 0;
    color: var(--color-text);
    font-size: var(--text-lg);
    font-weight: 700;
    line-height: var(--line-height-tight);
    padding: 0;
  }

  .callout-body {
    margin-block-start: var(--space-3);
    color: var(--color-text);
    font-size: var(--text-base);
  }

  .callout-body :global(:first-child) {
    margin-block-start: 0;
  }

  .callout-body :global(:last-child) {
    margin-block-end: 0;
  }

  .callout-body :global(ul),
  .callout-body :global(ol) {
    padding-inline-start: 1.35rem;
  }

  .callout-body :global(a) {
    color: var(--color-link);
  }

  .callout-body :global(small) {
    color: var(--callout-muted);
  }

  @media (max-width: 640px) {
    .callout {
      padding: var(--space-4);
    }

    .callout-title {
      font-size: var(--text-base);
    }

    .callout-body {
      font-size: var(--text-sm);
    }
  }
</style>
