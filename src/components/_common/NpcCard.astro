---
import { withBase } from "../../lib/utils/paths";
import type { Npc } from "../../lib/types/npc";

interface Props {
  npc: Npc;
  portraitPath: string;
  portraitPosition?: "left" | "right";
}

const { npc, portraitPath, portraitPosition = "left" } = Astro.props;
---

<article
  class:list={["npc-card", `npc-card-${portraitPosition}`]}
  data-npc-card
  data-npc-portrait-position={portraitPosition}
>
  <div class="npc-card-portrait">
    <img src={withBase(portraitPath)} alt={`${npc.name}の肖像`} loading="lazy" decoding="async" />
  </div>

  <div class="npc-card-content">
    <h4 class="npc-card-name">
      {
        npc.epithet && (
          <span class="npc-card-epithet">
            <ruby>
              {npc.epithet.text}
              <rt>{npc.epithet.reading}</rt>
            </ruby>
          </span>
        )
      }
      {npc.epithet ? " " : null}
      {npc.name}
    </h4>
    <p class="npc-card-quote">{npc.quote}</p>
    <p class="npc-card-description">{npc.description}</p>
  </div>
</article>

<style>
  .npc-card {
    display: grid;
    grid-template-columns: 8.25rem minmax(0, 1fr);
    min-width: 0;
    border: var(--border-width) solid var(--color-border);
    background: var(--color-surface);
  }

  .npc-card-portrait {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-right: var(--border-width) solid var(--color-border);
    background: var(--color-surface-muted);
  }

  .npc-card-portrait img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .npc-card-content {
    align-self: center;
    min-width: 0;
    padding: var(--space-5) var(--space-6);
  }

  .npc-card-name {
    margin: 0;
    color: var(--color-text);
    font-size: var(--text-xl);
    line-height: var(--line-height-tight);
  }

  .npc-card-epithet {
    color: var(--color-link-hover);
    font-style: normal;
    font-weight: 600;
  }

  .npc-card-epithet ruby {
    ruby-position: over;
  }

  .npc-card-epithet rt {
    color: var(--color-link-hover);
    font-size: 0.55em;
    font-style: normal;
    font-weight: 700;
  }

  .npc-card-content p {
    margin: var(--space-3) 0 0;
    font-size: var(--text-sm);
    line-height: var(--line-height-base);
  }

  .npc-card-quote {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .npc-card-description {
    color: var(--color-text);
  }

  .npc-card-right {
    grid-template-columns: minmax(0, 1fr) 8.25rem;
  }

  .npc-card-right .npc-card-portrait {
    grid-column: 2;
    border-right: 0;
    border-left: var(--border-width) solid var(--color-border);
  }

  .npc-card-right .npc-card-content {
    grid-row: 1;
    grid-column: 1;
  }

  @media (max-width: 48rem) {
    .npc-card {
      grid-template-columns: 6.375rem minmax(0, 1fr);
    }

    .npc-card-right {
      grid-template-columns: minmax(0, 1fr) 6.375rem;
    }

    .npc-card-content {
      padding: var(--space-3) var(--space-4);
    }

    .npc-card-name {
      font-size: var(--text-lg);
    }

    .npc-card-content p {
      margin-top: var(--space-2);
      font-size: var(--text-sm);
      line-height: 1.6;
    }
  }
</style>
