---
interface Props {
  ariaLabel?: string;
}

const { ariaLabel } = Astro.props;
---

<div class="card-container" data-card-container aria-label={ariaLabel}>
  <slot />
</div>

<style>
  .card-container {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: stretch;
    gap: var(--space-4);
    margin-top: var(--space-5);
  }

  @media (max-width: 48rem) {
    .card-container {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--space-3);
      margin-top: var(--space-4);
    }
  }
</style>
