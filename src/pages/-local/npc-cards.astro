---
import NpcCard from "../../components/_common/NpcCard.astro";
import { getNpcList, getNpcPortraitPath } from "../../lib/data/npcs";
import AppContainer from "../../layouts/AppContainer.astro";

const npcCards = getNpcList();
---

<AppContainer
  title="NPCカード カタログ"
  description="NpcCard Componentのローカル確認用カタログです。"
  showPageToc={false}
>
  <article class="npc-card-catalog prose" data-npc-card-catalog>
    <h1>NPCカード カタログ</h1>
    <p class="npc-card-catalog-lead">
      NpcCardの横長1列レイアウト、個別画像、左右の画像位置を確認するローカルページです。
    </p>

    <div class="npc-card-list" aria-label="NPCカードの表示例">
      {
        npcCards.map((npc, index) => (
          <NpcCard
            npc={npc}
            portraitPath={getNpcPortraitPath(npc.id)}
            portraitPosition={index % 2 === 0 ? "left" : "right"}
          />
        ))
      }
    </div>
  </article>
</AppContainer>

<style>
  .npc-card-catalog {
    max-width: 47.5rem;
  }

  .npc-card-catalog-lead {
    max-width: 46rem;
    color: var(--color-text-muted);
  }

  .npc-card-list {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }
</style>
