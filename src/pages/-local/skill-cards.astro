---
import CardContainer from "../../components/_common/CardContainer.astro";
import SkillCard from "../../components/data/SkillCard.astro";
import AppContainer from "../../layouts/AppContainer.astro";

const effectSeed = "街の気配と人の流れを読み、仕事人は危険を避けながら次の一手を選ぶ。";

function repeatedEffect(length: number): string {
  return Array.from(effectSeed.repeat(Math.ceil(length / effectSeed.length)))
    .slice(0, length)
    .join("");
}

const skillGroups = [
  {
    heading: "ボーナススキル",
    skills: [
      {
        anchorId: "skill-common-bonus-a-1",
        name: "基本の一撃",
        maxLevel: 1,
        timing: "○-○",
        cost: "気0",
        proficiency: "能動",
        acquisitionRestriction: "自動習得",
        usageRestriction: null,
        target: "1体",
        range: "武器",
        summary: "",
        effect: "対象に攻撃を行なう。",
      },
    ],
  },
  {
    heading: "基本スキル",
    skills: [
      {
        anchorId: "skill-common-basic-m-1",
        name: "踏み込み",
        maxLevel: 3,
        timing: "M",
        cost: "気2",
        proficiency: "軽業",
        acquisitionRestriction: "基本の一撃",
        usageRestriction: "1/R",
        target: "自身",
        range: "0",
        summary: "危険を避けるため、素早く間合いを詰める。",
        effect: "移動後に行う次の判定へ補正を得る。",
      },
      {
        anchorId: "skill-common-basic-r-1",
        name: "受け流し",
        maxLevel: 2,
        timing: "R",
        cost: "体1",
        proficiency: "受動",
        acquisitionRestriction: null,
        usageRestriction: "LV/R",
        target: "自身",
        range: "0",
        summary: "受けた攻撃の勢いを逸らす。",
        effect: "受動側の判定に補正を得る。",
      },
      {
        anchorId: "skill-common-basic-aa-1",
        name: "狙い澄ます",
        maxLevel: 3,
        timing: "Aa",
        cost: "精1",
        proficiency: "発砲",
        acquisitionRestriction: null,
        usageRestriction: "1/R",
        target: "1体",
        range: "武器",
        summary: "一瞬の隙を逃さず、照準を定め直す。",
        effect: "攻撃の判定直後に使用する。",
      },
    ],
  },
  {
    heading: "上級スキル",
    skills: [
      {
        anchorId: "skill-common-advanced-sp-1",
        name: "交渉の余地",
        maxLevel: 4,
        timing: "SP",
        cost: "精SP",
        proficiency: "交渉",
        acquisitionRestriction: "プライマリ限定",
        usageRestriction: "1/Sc",
        target: "シーン",
        range: "シーン",
        summary: "",
        effect: repeatedEffect(200),
      },
      {
        anchorId: "skill-common-advanced-pv-1",
        name: "路地の勘",
        maxLevel: 2,
        timing: "Pv",
        cost: null,
        proficiency: "危険察知",
        acquisitionRestriction: null,
        usageRestriction: null,
        target: "自身",
        range: null,
        summary: "",
        effect: `${repeatedEffect(100)}\n${repeatedEffect(100)}\n${repeatedEffect(100)}`,
      },
    ],
  },
];
---

<AppContainer
  title="スキルカード カタログ"
  description="SkillCard Componentのローカル確認用カタログです。"
  showPageToc={true}
>
  <article class="skill-card-catalog prose" data-skill-card-catalog>
    <h1>共通スキル</h1>
    <p class="skill-card-catalog-lead">
      SkillCardの表示密度、本文量、desktop 3列とmobile 2列のレイアウトを確認するローカルページです。
    </p>

    {
      skillGroups.map((group) => (
        <section class="skill-card-section" aria-labelledby={`skill-group-${group.heading}`}>
          <h2 id={`skill-group-${group.heading}`}>{group.heading}</h2>
          <CardContainer ariaLabel={`${group.heading}の表示例`}>
            {group.skills.map((skill) => <SkillCard {...skill} />)}
          </CardContainer>
        </section>
      ))
    }
  </article>
</AppContainer>

<style>
  .skill-card-catalog {
    max-width: none;
  }

  .skill-card-catalog-lead {
    max-width: 46rem;
    color: var(--color-text-muted);
  }

  .skill-card-section {
    margin-top: var(--space-10);
  }

  @media (max-width: 48rem) {
    .skill-card-section {
      margin-top: var(--space-8);
    }
  }
</style>
