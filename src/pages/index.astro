---
import ContentLayout from "../layouts/ContentLayout.astro";
import { withBase } from "../lib/utils/paths";

const title = "ネオン・アンダーレルムTRPG";
const description =
  "ネオン・アンダーレルムTRPGのルール、データ、更新情報を公開するサイトです。";
const mdxTestPath = withBase("/mdx-test/");
---

<ContentLayout title={title} description={description} showPageToc={false}>
  <h1>{title}</h1>
  <p>ルールサイト初期化中です。</p>
  <p><a href={mdxTestPath}>MDX表示確認</a></p>
</ContentLayout>
