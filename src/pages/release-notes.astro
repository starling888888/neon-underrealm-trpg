---
import NoTocPageLayout from "../layouts/NoTocPageLayout.astro";
import { getReleaseNoteBody, getReleaseNotes } from "../lib/data/release-notes";

const title = "更新履歴";
const description = "更新履歴ページです。";
const releaseNotes = getReleaseNotes();
---

<NoTocPageLayout title={title} description={description} contentClass="release-notes-page">
  <h1>{title}</h1>

  {
    releaseNotes.length > 0 ? (
      <ol class="release-notes-list">
        {releaseNotes.map((note) => (
          <li class="release-notes-item">
            <time class="release-notes-date" datetime={note.date}>
              {note.date}
            </time>
            <p class="release-notes-body">{getReleaseNoteBody(note)}</p>
          </li>
        ))}
      </ol>
    ) : (
      <p class="release-notes-empty">更新履歴はまだありません。</p>
    )
  }
</NoTocPageLayout>

<style>
  .release-notes-list {
    display: grid;
    margin-block: var(--space-8) 0;
    padding: 0;
    border-block: var(--border-width) solid var(--color-border);
    list-style: none;
  }

  .release-notes-item {
    display: grid;
    gap: var(--space-4);
    margin: 0;
    border-block-end: var(--border-width) solid var(--color-border);
    padding-block: var(--space-6);
  }

  .release-notes-item:last-child {
    border-block-end: 0;
  }

  .release-notes-date {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-variant-numeric: tabular-nums;
    line-height: var(--line-height-base);
  }

  :global(.release-notes-page h1::after) {
    background: var(--color-accent);
  }

  .release-notes-body {
    margin: 0;
    line-height: var(--line-height-relaxed);
    white-space: pre-line;
  }

  .release-notes-empty {
    margin-block: var(--space-8) 0;
    color: var(--color-text-muted);
  }

  @media (max-width: 48rem) {
    .release-notes-list {
      margin-block-start: var(--space-8);
    }

    .release-notes-item {
      gap: var(--space-3);
      padding-block: var(--space-5);
    }
  }
</style>
