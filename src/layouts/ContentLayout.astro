---
import BaseLayout from "./BaseLayout.astro";
import type { SeoProps } from "../lib/site/seo";

export interface Props extends SeoProps {
  title?: string;
  description?: string;
}

const {
  title,
  description,
  ogTitle,
  ogDescription,
  ogType,
  ogImage,
  ogUrl,
  twitterCard,
  noindex,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  ogTitle={ogTitle}
  ogDescription={ogDescription}
  ogType={ogType}
  ogImage={ogImage}
  ogUrl={ogUrl}
  twitterCard={twitterCard}
  noindex={noindex}
>
  <article class="content-layout prose">
    <slot />
  </article>
</BaseLayout>

<style>
  .content-layout {
    max-width: var(--content-width);
  }
</style>
