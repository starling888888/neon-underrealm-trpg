---
import "../styles/global.css";
import "../styles/prose.css";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import MobileSiteMenuDrawer from "../components/layout/MobileSiteMenuDrawer.astro";
import SearchModal from "../components/search/SearchModal.astro";
import Seo from "../components/seo/Seo.astro";
import type { SeoProps } from "../lib/site/seo";
import { defaultSeo } from "../lib/site/seo";
import { withBase } from "../lib/utils/paths";
import TocPageLayout from "./TocPageLayout.astro";
import NoTocPageLayout from "./NoTocPageLayout.astro";

export interface Props extends SeoProps {
  title?: string;
  description?: string;
  showPageToc?: boolean;
}

const {
  title,
  description = defaultSeo.description,
  ogTitle,
  ogDescription,
  ogType,
  ogImage,
  ogUrl,
  twitterCard,
  noindex,
  showPageToc = false,
} = Astro.props;

const PageLayout = showPageToc ? TocPageLayout : NoTocPageLayout;

function getSearchTypeLabel(pathname: string): string {
  const basePath = import.meta.env.BASE_URL.replace(/\/$/, "");
  const path = pathname.startsWith(basePath)
    ? pathname.slice(basePath.length) || "/"
    : pathname;

  if (path === "/") {
    return "トップ";
  }

  if (path.startsWith("/data/")) {
    return "データ";
  }

  if (path.startsWith("/rules/") || path === "/advancement/" || path === "/character-making/") {
    return "ルール";
  }

  if (path === "/release-notes/") {
    return "更新履歴";
  }

  if (path === "/world/") {
    return "ワールド";
  }

  return "本文";
}

const searchTypeLabel = getSearchTypeLabel(Astro.url.pathname);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta data-pagefind-meta="type[content]" content={searchTypeLabel} />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
    <Seo
      title={title}
      description={description}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogType={ogType}
      ogImage={ogImage}
      ogUrl={ogUrl}
      twitterCard={twitterCard}
      noindex={noindex}
    />
  </head>
  <body>
    <div class="site-shell">
      <Header />

      <SearchModal />

      <MobileSiteMenuDrawer />

      <PageLayout>
        <slot />
      </PageLayout>

      <Footer />
    </div>
  </body>
</html>

<script>
  import { setupMobileHeader } from "../scripts/mobile-header";
  import { setupMobileMenu } from "../scripts/mobile-menu";
  import {
    setupSearchHighlight,
    setupSearchModal,
  } from "../scripts/search-modal";

  setupMobileHeader();
  setupMobileMenu();
  setupSearchModal();
  setupSearchHighlight();
</script>

<style>
  .site-shell {
    width: 100%;
    min-width: 1120px;
    min-height: 100vh;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    background: var(--color-surface);
    padding-block-start: var(--site-header-height);
  }

  :global([data-pagefind-body] mark.pagefind-highlight) {
    border-radius: var(--radius-sm);
    background: var(--color-accent-soft);
    color: inherit;
    padding-inline: 0.0625em;
  }

  @media (max-width: 63.999rem) {
    .site-shell {
      min-width: 0;
    }
  }

  @media (width < 48rem) {
    .site-shell {
      min-width: 0;
    }
  }
</style>
