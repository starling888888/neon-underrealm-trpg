---
import "../styles/global.css";
import "../styles/prose.css";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import SiteMenu from "../components/layout/SiteMenu.astro";
import Seo from "../components/seo/Seo.astro";
import type { SeoProps } from "../lib/site/seo";
import { defaultSeo } from "../lib/site/seo";

export interface Props extends SeoProps {
  title?: string;
  description?: string;
}

const {
  title = defaultSeo.title,
  description = defaultSeo.description,
  ogTitle,
  ogDescription,
  ogType,
  ogImage,
  ogUrl,
  twitterCard,
  noindex,
} = Astro.props;

---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <Seo
      title={title}
      description={description}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogType={ogType}
      ogImage={ogImage}
      ogUrl={ogUrl}
      twitterCard={twitterCard}
      noindex={noindex}
    />
  </head>
  <body>
    <div class="site-shell">
      <Header />

      <div class="desktop-layout">
        <aside class="layout-rail layout-rail-left">
          <SiteMenu />
        </aside>

        <main class="site-main">
          <slot />
        </main>

        <aside class="layout-rail layout-rail-right" aria-label="補助領域プレースホルダー">
          <p class="rail-heading">補助領域プレースホルダー</p>
          <div class="rail-group" aria-hidden="true">
            <span class="rail-line rail-line-strong"></span>
            <span class="rail-line rail-line-medium"></span>
            <span class="rail-line"></span>
            <span class="rail-line rail-line-short"></span>
          </div>
          <div class="rail-group" aria-hidden="true">
            <span class="rail-line rail-line-strong rail-line-medium"></span>
            <span class="rail-line"></span>
            <span class="rail-line rail-line-short"></span>
          </div>
        </aside>
      </div>

      <Footer />
    </div>
  </body>
</html>

<style>
  .site-shell {
    min-width: 1120px;
    min-height: 100vh;
    display: grid;
    grid-template-rows: auto 1fr auto;
    background: var(--color-surface);
  }

  .desktop-layout {
    display: grid;
    grid-template-columns: 19.5rem minmax(46rem, 1fr) 19.5rem;
    min-height: calc(100vh - 9rem);
  }

  .layout-rail {
    padding: var(--space-8) var(--space-6);
  }

  .layout-rail-left {
    border-right: var(--border-width) solid var(--color-border);
    background: var(--color-surface-muted);
  }

  .layout-rail-right {
    border-left: var(--border-width) solid var(--color-border);
    background: var(--color-surface);
  }

  .rail-heading {
    margin: 0 0 var(--space-8);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .rail-group {
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-6);
    border-top: var(--border-width) solid var(--color-border);
  }

  .rail-group:first-of-type {
    border-top: 0;
    padding-block-start: 0;
  }

  .rail-line {
    display: block;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--color-border-strong) 66%, white);
  }

  .rail-line {
    width: 9rem;
    height: 0.5rem;
    opacity: 0.64;
  }

  .rail-line-strong {
    width: 8rem;
    opacity: 0.9;
  }

  .rail-line-medium {
    width: 7rem;
  }

  .rail-line-short {
    width: 5.5rem;
  }

  .rail-group .rail-line:not(.rail-line-strong) {
    margin-left: var(--space-6);
  }

  .site-main {
    width: min(100% - (var(--page-gutter) * 2), var(--content-wide-width));
    margin-inline: auto;
    padding-block: var(--space-12);
  }

  @media (max-width: 48rem) {
    .site-shell {
      min-width: 0;
    }

    .desktop-layout {
      display: block;
      min-height: 0;
    }

    .layout-rail {
      display: none;
    }
  }
</style>
