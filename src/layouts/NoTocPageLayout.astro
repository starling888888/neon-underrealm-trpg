---
import SiteMenu from "../components/layout/SiteMenu.astro";

export interface Props {
  variant?: "default" | "character-sheet";
}

const { variant = "default" } = Astro.props;
---

<div class={`desktop-layout-no-toc layout-variant-${variant}`}>
  <aside class="layout-rail layout-rail-left">
    <SiteMenu />
  </aside>

  <main class="site-main" data-page-content data-pagefind-body>
    <div class="no-toc-page">
      <slot />
    </div>
  </main>
</div>

<style>
  .desktop-layout-no-toc {
    min-width: 0;
    display: grid;
    grid-template-columns: 15rem minmax(46rem, 1fr);
    min-height: calc(100vh - 9rem);
  }

  .layout-rail {
    min-height: 0;
    padding-block: var(--space-8);
    padding-inline: var(--space-3) var(--space-2);
  }

  .layout-rail-left {
    border-right: var(--border-width) solid var(--color-border);
    background: var(--color-surface-muted);
  }

  .site-main {
    min-width: 0;
    width: min(100% - (var(--page-gutter) * 2), var(--content-wide-width));
    margin-inline: auto;
    padding-block: var(--space-6);
  }

  .no-toc-page {
    max-width: min(100%, 56rem);
    margin-inline: auto;
    padding: var(--space-10) var(--space-12);
  }

  @media (max-width: 79.999rem) {
    .desktop-layout-no-toc {
      grid-template-columns: 15rem minmax(0, 1fr);
    }
  }

  @media (width < 48rem) {
    .desktop-layout-no-toc {
      display: block;
      min-height: 0;
    }

    .no-toc-page {
      padding: var(--space-6) var(--space-5);
    }

    .layout-rail {
      display: none;
    }
  }

  @media (width >= 48rem) {
    .no-toc-page {
      max-width: min(100%, 62rem);
      padding: var(--space-5) var(--space-6);
    }
  }
</style>
