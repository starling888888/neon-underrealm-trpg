---
import "../styles/global.css";
import "../styles/prose.css";
import Footer from "../components/layout/Footer.astro";
import SearchModal from "../components/search/SearchModal.astro";
import Seo from "../components/seo/Seo.astro";
import { defaultSeo } from "../lib/site/seo";
import type { SeoProps } from "../lib/site/seo";
import { getSearchTypeLabel } from "../lib/search/page-metadata";
import { withBase } from "../lib/utils/paths";
import CharacterSheetHeader from "../components/character-sheet/CharacterSheetHeader.astro";
import CharacterSheetPageLayout from "./CharacterSheetPageLayout.astro";

export interface Props extends SeoProps {
  title?: string;
  description?: string;
}

const {
  title,
  description = defaultSeo.description,
  ogTitle,
  ogDescription,
  ogType,
  ogImage,
  ogUrl,
  twitterCard,
  noindex,
} = Astro.props;

const searchTypeLabel = getSearchTypeLabel(
  Astro.url.pathname,
  import.meta.env.BASE_URL,
);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta data-pagefind-meta="type[content]" content={searchTypeLabel} />
    <link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
    <Seo
      title={title}
      description={description}
      ogTitle={ogTitle}
      ogDescription={ogDescription}
      ogType={ogType}
      ogImage={ogImage}
      ogUrl={ogUrl}
      twitterCard={twitterCard}
      noindex={noindex}
    />
  </head>
  <body>
    <div class="character-sheet-shell">
      <CharacterSheetHeader />

      <SearchModal />

      <CharacterSheetPageLayout>
        <slot />
      </CharacterSheetPageLayout>

      <Footer />
    </div>
  </body>
</html>

<script>
  import { setupMobileHeader } from "../scripts/mobile-header";
  import {
    setupSearchHighlight,
    setupSearchModal,
  } from "../scripts/search-modal";

  setupMobileHeader();
  setupSearchModal();
  setupSearchHighlight();
</script>

<style>
  .character-sheet-shell {
    width: 100%;
    min-height: 100vh;
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    background: var(--color-surface);
    padding-block-start: var(--site-header-height);
  }

  :global([data-pagefind-body] mark.pagefind-highlight) {
    border-radius: var(--radius-sm);
    background: #ffe36e;
    color: var(--color-text);
    padding-inline: 0.0625em;
  }
</style>
