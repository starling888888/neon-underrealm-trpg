{
  "name": "neon-underrealm-trpg",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node --import tsx scripts/postprocess-page-toc/main.ts",
    "preview": "astro preview",
    "convert:npcs": "node --import tsx scripts/convert-npcs/main.ts",
    "convert:items": "node --import tsx scripts/convert-items/main.ts",
    "convert:common-skills": "node --import tsx scripts/convert-common-skills/main.ts",
    "convert:ryugi-skills": "node --import tsx scripts/convert-ryugi-skills/main.ts",
    "convert:ryugi-list": "node --import tsx scripts/convert-ryugi-index/main.ts",
    "convert:ikizama": "node --import tsx scripts/convert-ikizama-index/main.ts",
    "convert:ikizama-skills": "node --import tsx scripts/convert-ikizama-skills/main.ts",
    "convert:release-notes": "node --import tsx scripts/convert-release-notes/main.ts",
    "convert:ryugi-data": "run-s convert:ryugi-list convert:ryugi-skills",
    "convert:ikizama-data": "run-s convert:ikizama convert:ikizama-skills",
    "convert:data": "run-p convert:npcs convert:items convert:common-skills convert:release-notes convert:ryugi-data convert:ikizama-data",
    "test": "run-s test:node test:page-navigation-contract",
    "test:node": "mkdir -p test-results && node --import tsx --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=tap --test-reporter-destination=test-results/node-tests.tap tests/node/**/*.test.ts",
    "test:page-navigation-contract": "npm run build:public && node --import tsx --test tests/contract/page-navigation-build.test.ts",
    "check": "astro check && biome check . && npm run check:md",
    "check:astro": "astro check",
    "check:md": "DPRINT_CACHE_DIR=\"$PWD/.dprint-cache\" dprint check && markdownlint-cli2",
    "build:public": "npm run build && node --import tsx scripts/remove-private-routes/main.ts",
    "build:search-index": "pagefind --site dist",
    "lint": "biome lint .",
    "format": "biome format --write . && npm run format:md",
    "format:md": "DPRINT_CACHE_DIR=\"$PWD/.dprint-cache\" dprint fmt && markdownlint-cli2 --fix",
    "visual:build": "npm run build && pagefind --site dist",
    "visual:test": "playwright test tests/visual/vrt --workers=1",
    "visual:update": "playwright test tests/visual/vrt --workers=1 --update-snapshots",
    "visual:install": "playwright install chromium"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "astro": "^7.0.6",
    "parse5": "^8.0.1",
    "simple-icons": "^16.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.2",
    "@dprint/markdown": "^0.22.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "dprint": "^0.55.1",
    "fflate": "^0.8.3",
    "markdownlint-cli2": "^0.23.0",
    "npm-run-all2": "^8.0.4",
    "pagefind": "^1.5.2",
    "read-excel-file": "^9.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
