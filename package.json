{
  "name": "neon-underrealm-trpg",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node --import tsx scripts/postprocess-page-toc/main.ts",
    "preview": "astro preview",
    "convert:common-skills": "node --import tsx scripts/convert-common-skills/main.ts",
    "convert:ryugi-list": "node --import tsx scripts/convert-ryugi-index/main.ts",
    "convert:release-notes": "node --import tsx scripts/convert-release-notes/main.ts",
    "test": "mkdir -p test-results && node --import tsx --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=tap --test-reporter-destination=test-results/node-tests.tap tests/node/**/*.test.ts",
    "check": "astro check && biome check . && npm run check:md",
    "check:astro": "astro check",
    "check:md": "DPRINT_CACHE_DIR=\"$PWD/.dprint-cache\" dprint check && markdownlint-cli2",
    "build:public": "npm run build && node --import tsx scripts/remove-private-routes/main.ts",
    "build:search-index": "pagefind --site dist",
    "lint": "biome lint .",
    "format": "biome format --write . && npm run format:md",
    "format:md": "DPRINT_CACHE_DIR=\"$PWD/.dprint-cache\" dprint fmt && markdownlint-cli2 --fix",
    "visual:capture": "node --import tsx scripts/visual-capture/main.ts",
    "visual:canonicalize": "node --import tsx scripts/canonicalize-visual-design/main.ts",
    "visual:install": "playwright install chromium"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.2",
    "astro": "^7.0.6",
    "parse5": "^8.0.1",
    "simple-icons": "^16.25.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.2",
    "@dprint/markdown": "^0.22.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.0",
    "dprint": "^0.55.1",
    "fflate": "^0.8.3",
    "markdownlint-cli2": "^0.23.0",
    "pagefind": "^1.5.2",
    "read-excel-file": "^9.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3"
  }
}
